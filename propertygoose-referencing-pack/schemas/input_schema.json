{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PropertyGooseReferencingInput",
  "type": "object",
  "required": [
    "monthly_rent_total",
    "rent_share_fraction",
    "tenancy_months",
    "credit_events",
    "id_check",
    "aml_pep_sanctions",
    "income",
    "landlord_ref",
    "bank_validation_present",
    "needs_rent_protection_underwriting"
  ],
  "properties": {
    "monthly_rent_total": {
      "type": "number",
      "minimum": 0
    },
    "rent_share_fraction": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "tenancy_months": {
      "type": "integer",
      "minimum": 1
    },
    "tas_score": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 0
    },
    "credit_events": {
      "type": "object",
      "required": [
        "declared_ccjs",
        "declared_iva",
        "declared_bankruptcy",
        "undeclared_adverse_found",
        "has_score"
      ],
      "properties": {
        "declared_ccjs": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "amount": {
                "type": "number",
                "minimum": 0
              },
              "satisfied": {
                "type": "boolean"
              }
            },
            "required": [
              "amount",
              "satisfied"
            ]
          }
        },
        "declared_iva": {
          "type": "boolean"
        },
        "declared_bankruptcy": {
          "type": "boolean"
        },
        "undeclared_adverse_found": {
          "type": "boolean"
        },
        "has_score": {
          "type": "boolean"
        }
      }
    },
    "id_check": {
      "type": "object",
      "required": [
        "passed",
        "document_fraud",
        "proof_of_residency_received"
      ],
      "properties": {
        "passed": {
          "type": "boolean"
        },
        "document_fraud": {
          "type": "boolean"
        },
        "proof_of_residency_received": {
          "type": "boolean"
        }
      }
    },
    "aml_pep_sanctions": {
      "type": "object",
      "required": [
        "sanctions_match",
        "pep",
        "aml_adverse"
      ],
      "properties": {
        "sanctions_match": {
          "type": "boolean"
        },
        "pep": {
          "type": "boolean"
        },
        "aml_adverse": {
          "type": "boolean"
        }
      }
    },
    "income": {
      "type": "object",
      "required": [
        "type",
        "gross_annual",
        "start_in_days",
        "contract",
        "self_employed_years",
        "independent_means"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "employed",
            "self_employed",
            "temp",
            "benefits",
            "pension",
            "unemployed"
          ]
        },
        "gross_annual": {
          "type": "number",
          "minimum": 0
        },
        "start_in_days": {
          "type": "integer"
        },
        "contract": {
          "type": "string"
        },
        "professional_role": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "self_employed_years": {
          "type": "number",
          "minimum": 0
        },
        "independent_means": {
          "type": "object",
          "required": [
            "has_proof",
            "funds_for_term"
          ],
          "properties": {
            "has_proof": {
              "type": "boolean"
            },
            "funds_for_term": {
              "type": "number",
              "minimum": 0
            }
          }
        }
      }
    },
    "landlord_ref": {
      "type": "object",
      "required": [
        "received",
        "arrears",
        "property_care",
        "notes"
      ],
      "properties": {
        "received": {
          "type": "boolean"
        },
        "arrears": {
          "type": "string",
          "enum": [
            "none",
            "minor_cleared",
            "severe",
            "unknown"
          ]
        },
        "property_care": {
          "type": "string",
          "enum": [
            "good",
            "fair",
            "bad",
            "unknown"
          ]
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "bank_validation_present": {
      "type": "boolean"
    },
    "needs_rent_protection_underwriting": {
      "type": "boolean"
    }
  }
}