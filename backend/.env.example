# Supabase Configuration
SUPABASE_URL=your_supabase_url_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Server Configuration
PORT=3001
NODE_ENV=development

# Frontend URL for CORS (only needed in production)
FRONTEND_URL=http://localhost:5173

# Encryption Key (Generate with: openssl rand -base64 32)
# CRITICAL: Keep this secret and never commit to version control
ENCRYPTION_KEY=your_base64_encryption_key_here

# Creditsafe API Configuration
# Sign up at https://www.creditsafe.com/ to get credentials
# Login credentials from: https://connect-portal.creditsafe.com/search
CREDITSAFE_ENABLED=false
CREDITSAFE_API_URL=https://connect.sandbox.creditsafe.com/v1
# For production, use: https://connect.creditsafe.com/v1
CREDITSAFE_USERNAME=your_creditsafe_username_here
CREDITSAFE_PASSWORD=your_creditsafe_password_here

# Stripe Configuration
# Sign up at https://stripe.com/ and get your API keys from the dashboard
# For testing, use test mode keys (pk_test_... and sk_test_...)
# For production, use live mode keys (pk_live_... and sk_live_...)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret_here
